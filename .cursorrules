{
  "name": "Scenario Route Migration",
  "version": "1.0.0",
  "rules": [
    {
      "name": "Change Detection",
      "description": "Check for changes and prompt for documentation updates",
      "trigger": "file_change",
      "action": {
        "type": "prompt",
        "message": "Would you like to document these changes in the migration plan and changelog?",
        "options": [
          "Yes",
          "No"
        ]
      }
    },
    {
      "name": "Update Migration Plan",
      "description": "Update the migration plan markdown file when a task is completed",
      "trigger": "task_complete",
      "action": {
        "type": "edit_file",
        "file": "docs/migration-plan.md",
        "pattern": "- \\[ \\] (.*?)$",
        "replace": "- [x] $1"
      },
      "conditions": [
        {
          "type": "file_exists",
          "path": "docs/migration-plan.md"
        }
      ]
    },
    {
      "name": "Task Completion Check",
      "description": "Verify task completion before updating markdown",
      "trigger": "before_task_complete",
      "action": {
        "type": "prompt",
        "message": "Have you completed the task and tested it thoroughly?",
        "options": [
          "Yes",
          "No"
        ]
      }
    },
    {
      "name": "Document Changes",
      "description": "Create a changelog entry for completed tasks",
      "trigger": "task_complete",
      "action": {
        "type": "edit_file",
        "file": "docs/CHANGELOG.md",
        "append": true,
        "content": "\n## [Unreleased]\n### Added\n- Completed task: {task_name}\n### Changed\n- Updated migration plan with completed task"
      }
    },
    {
      "name": "Next Task Reminder",
      "description": "Show next pending task after completion",
      "trigger": "task_complete",
      "action": {
        "type": "prompt",
        "message": "Would you like to see the next pending task?",
        "options": [
          "Yes",
          "No"
        ]
      }
    },
    {
      "name": "Change Documentation",
      "description": "Document changes in migration plan and changelog",
      "trigger": "document_changes",
      "action": {
        "type": "prompt",
        "message": "Please describe the changes you made:",
        "input_type": "text"
      },
      "post_action": {
        "type": "edit_file",
        "file": "docs/CHANGELOG.md",
        "append": true,
        "content": "\n### Changed\n- {change_description}"
      }
    }
  ],
  "tasks": {
    "route_setup": {
      "name": "Route Setup",
      "subtasks": [
        "Create Dynamic Route Structure",
        "Implement Basic Page Component",
        "Set Up Error and Loading Boundaries"
      ]
    },
    "data_layer": {
      "name": "Data Layer",
      "subtasks": [
        "Server-Side Data Fetching",
        "Static Path Generation",
        "Metadata Generation"
      ]
    },
    "state_management": {
      "name": "State Management",
      "subtasks": [
        "Scenario Context",
        "URL State Management",
        "Navigation Components"
      ]
    },
    "ui_components": {
      "name": "UI Components",
      "subtasks": [
        "Scenario Navigation",
        "Loading States",
        "Error Boundaries"
      ]
    },
    "testing_optimization": {
      "name": "Testing & Optimization",
      "subtasks": [
        "Testing",
        "Performance Optimization",
        "Monitoring"
      ]
    }
  },
  "notifications": {
    "on_task_complete": {
      "type": "toast",
      "message": "Task completed! Migration plan has been updated."
    },
    "on_next_task": {
      "type": "toast",
      "message": "Next task: {next_task}"
    },
    "on_change": {
      "type": "toast",
      "message": "Changes detected. Please document them."
    }
  }
}
